{
  "project_metadata": {
    "flutter": "/Users/admin/anystories-client-flutter",
    "ios": "/Users/admin/novelspa"
  },
  "functional_capability_map": {
    "IAP_PAYMENT": {
      "flutter": {
        "logic_center": "lib/ui/screens/reader/service/purchase_service.dart",
        "iap_adapter": "in_app_purchase (plugin)",
        "models": "lib/models/atom/purchase_resp.dart"
      },
      "ios": {
        "logic_center": "novelspa/Utils/InAppPurchase/InAppPurchase.swift (IOSPurchaseManager)",
        "persistence": "Keychain (for uncompleted orders)",
        "models": "novelspa/SwiftUI/Api/UserCenterModel.swift"
      }
    },
    "MEMBERSHIP_CENTER": {
      "flutter": {
        "ui": "lib/ui/screens/audio/buy/membership_unlock_v2_alert.dart",
        "theme": "MembershipUnlockV2Theme (in-file class)"
      },
      "ios": {
        "ui": "novelspa/Module/Vip/MembershipV2PopView.swift",
        "theme": "VipV2Theme (in-file struct)"
      }
    },
    "READER_CORE": {
      "flutter": {
        "state": "lib/ui/screens/reader/store/short_book_store.dart",
        "setting": "lib/ui/screens/reader/store/reader_setting_store.dart",
        "logic": "MobX-based Stores"
      },
      "ios": {
        "logic": "novelspa/Module/BookReader/Detail/Api/BookDetailApiManager.swift",
        "view_controller": "novelspa/Module/BookReader/Detail/ViewController.swift"
      }
    },
    "PERSISTENCE_CONFIG": {
      "flutter": {
        "util": "lib/locale/yj_cache.dart",
        "interface": "ReaderInterface"
      },
      "ios": {
        "util": "novelspa/Utils/Config/SettingManager.swift (SettingUserPreferences)",
        "wrapper": "@UserPreferences"
      }
    },
    "TRACKING_ANALYTICS": {
      "flutter": {
        "manager": "lib/services/user_event_collection/user_event_collection.dart",
        "mapping": "lib/services/sensors/mapping/event_mapping.dart"
      },
      "ios": {
        "manager": "novelspa/Utils/Tracker/Tracker/Sensors/SensorsTracker.swift",
        "table": "novelspa/Utils/Tracker/Tracker/Common/TrackerTable.swift"
      }
    }
  },
  "architectural_dna": {
    "flutter": "MobX + Store Pattern + Dio",
    "ios": "UIKit/SwiftUI + SnapKit + Moya + PromisesSwift",
    "migration_conventions": {
      "naming": "Snake_case -> PascalCase",
      "error_handling": "Try-Catch -> Result enum",
      "asynchrony": "Future/Async -> Promises/Callbacks"
    }
  }
}
